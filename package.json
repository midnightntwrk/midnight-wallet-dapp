{
  "name": "@midnight-ntwrk/midnight-wallet-dapp",
  "description": "Midnight Wallet Dapp demonstration application",
  "repository": "git@github.com:midnight-ntwrk/artifacts",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist node_modules/ vite.config.tsbuildinfo src/contract/build",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:docker": "docker build -t midnight-wallet-dapp .",
    "dapp:docker": "docker compose -f docker-compose.dapp.yml up -d dapp",
    "preview": "vite preview",
    "env:up": "TESTCONTAINERS_UID=999 docker compose -f compose.yml up -d",
    "env:up:latest": "TESTCONTAINERS_UID=777 docker compose -f compose_latest.yml up -d",
    "env:down": "docker compose -f compose.yml down",
    "env:down:latest": "docker compose -f compose_latest.yml down",
    "compact": "COMPACTC_VERSION=0.28.0 yarn fetch-compactc && yarn contract-demo",
    "contract-demo": "COMPACTC_VERSION=0.28.0 yarn run-compactc src/contract/contracts/unshielded-demo.compact src/contract/build/unshielded-demo",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/client": "^4.0.8",
    "@midnight-ntwrk/compact-js": "2.4.0",
    "@midnight-ntwrk/compact-runtime": "0.14.0",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v7": "7.0.2",
    "@midnight-ntwrk/midnight-js-contracts": "3.1.0",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "3.1.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.1.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.1.0",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "3.1.0",
    "@midnight-ntwrk/midnight-js-network-id": "3.1.0",
    "@midnight-ntwrk/midnight-js-types": "3.1.0",
    "@midnight-ntwrk/midnight-js-utils": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "2.0.0-rc.2",
    "bech32": "^2.0.0",
    "graphql": "^16.11.0",
    "graphql-ws": "^6.0.6",
    "isomorphic-ws": "^5.0.0",
    "level": "^10.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rxjs": "^7.8.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@midnight-ntwrk/midnight-js-compact": "^3.1.0",
    "@playwright/test": "^1.50.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vitejs/plugin-react": "^5.1.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "typescript": "^5.9.3",
    "util": "^0.12.5",
    "vite": "^7.1.12",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  },
  "resolutions": {
    "@midnight-ntwrk/ledger-v7": "7.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "3.1.0",
    "effect": "3.19.15"
  }
}
