{
  "name": "midnight-lace-dapp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist node_modules/ vite.config.tsbuildinfo src/contract/build",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:docker": "docker build -t midnight-lace-dapp .",
    "dapp:docker": "docker compose -f docker-compose.dapp.yml up -d dapp",
    "preview": "vite preview",
    "env:up": "TESTCONTAINERS_UID=999 docker compose -f compose.yml up -d",
    "env:down": "docker compose -f compose.yml down",
    "compact": "COMPACTC_VERSION=0.28.0-rc.0 yarn fetch-compactc && yarn contract-demo",
    "contract-demo": "COMPACTC_VERSION=0.28.0-rc.0 yarn run-compactc src/contract/contracts/unshielded-demo.compact src/contract/build/unshielded-demo"
  },
  "dependencies": {
    "@apollo/client": "^4.0.8",
    "@midnight-ntwrk/compact-runtime": "0.14.0-rc.0",
    "@midnight-ntwrk/dapp-connector-api": "^4.0.0-beta.2",
    "@midnight-ntwrk/ledger-v7": "7.0.0-rc.1",
    "@midnight-ntwrk/midnight-js-contracts": "3.0.0-alpha.15",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "3.0.0-alpha.15",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.0.0-alpha.15",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.0.0-alpha.15",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "3.0.0-alpha.15",
    "@midnight-ntwrk/midnight-js-network-id": "3.0.0-alpha.15",
    "@midnight-ntwrk/midnight-js-types": "3.0.0-alpha.15",
    "@midnight-ntwrk/midnight-js-utils": "3.0.0-alpha.15",
    "@midnight-ntwrk/wallet-sdk-facade": "1.0.0-beta.16",
    "bech32": "^2.0.0",
    "cross-fetch": "^4.1.0",
    "fetch-retry": "^6.0.0",
    "graphql": "^16.11.0",
    "graphql-ws": "^6.0.6",
    "isomorphic-ws": "^5.0.0",
    "level": "^10.0.0",
    "lodash": "^4.17.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rxjs": "^7.8.2",
    "superjson": "^2.2.5",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@midnight-ntwrk/midnight-js-compact": "^3.0.0-alpha.15",
    "@types/lodash": "^4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "typescript": "^5.9.3",
    "util": "^0.12.5",
    "vite": "^7.1.12",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  },
  "resolutions": {
    "@midnight-ntwrk/ledger-v7": "7.0.0-rc.1",
    "@midnight-ntwrk/midnight-js-network-id": "3.0.0-alpha.15"
  }
}
